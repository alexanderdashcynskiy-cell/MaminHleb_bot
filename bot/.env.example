# ── Обязательные ─────────────────────────────────────────────────────────────

# Токен бота (от @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram ID администратора (для check-in и уведомлений о заказах)
ADMIN_ID=

# ── База данных ───────────────────────────────────────────────────────────────

# Строка подключения PostgreSQL.
# Без неё состояние бота хранится только в памяти и теряется при каждом рестарте.
DATABASE_URL=postgresql://user:password@localhost:5432/maminhleb_bot

# SSL для PostgreSQL. На Railway оставь no-verify (Railway использует самоподписанный сертификат).
# Для собственного сервера с доверенным CA установи DATABASE_SSL=verify
# DATABASE_SSL=no-verify

# ── Webhook ───────────────────────────────────────────────────────────────────

# Railway автоматически выставляет RAILWAY_PUBLIC_DOMAIN — заполнять не нужно.
# При локальном запуске укажи ngrok/cloudflare tunnel URL:
# WEBHOOK_BASE_URL=https://abc123.ngrok.io

# Секрет для проверки X-Telegram-Bot-Api-Secret-Token и защиты /api/admin/checkin.
# Рекомендуется: случайная строка 32+ символов.
WEBHOOK_SECRET=

# ── Telegram чаты ─────────────────────────────────────────────────────────────

# Чат для уведомлений о заказах с доставкой (можно совпадать с ADMIN_ID)
DELIVERY_CHAT_ID=

# Чат для уведомлений о предзаказах
PREORDER_CHAT_ID=

# ── HTTP / CORS ───────────────────────────────────────────────────────────────

# Порт сервера (по умолчанию 3000; Railway подставляет автоматически)
PORT=3000

# Разрешённые CORS origins через запятую.
# По умолчанию: https://web.telegram.org, https://t.me
# ALLOWED_ORIGINS=https://web.telegram.org,https://t.me
