# Токен бота (от @BotFather)
BOT_TOKEN=

# ID группы/чата администратора (со знаком минус для групп)
ADMIN_ID=

# ID таблицы Google Sheets (из URL таблицы)
# Пример: https://docs.google.com/spreadsheets/d/ВОТ_ЭТОТ_ID/edit
SPREADSHEET_ID=

# Сервисный аккаунт Google (вставить содержимое JSON-файла одной строкой)
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# Railway автоматически подставляет RAILWAY_PUBLIC_DOMAIN — НЕ заполнять вручную
# Если запускаешь локально — укажи свой ngrok URL:
# WEBHOOK_BASE_URL=https://abc123.ngrok.io
