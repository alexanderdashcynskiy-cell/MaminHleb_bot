# ── Telegram ──────────────────────────────────────────────────────────────────
# Обязательно: токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Обязательно: ID администратора (личный чат)
ADMIN_ID=

# Обязательно: чат для уведомлений о доставке
DELIVERY_CHAT_ID=

# Обязательно: чат для предзаказов
PREORDER_CHAT_ID=

# Рекомендуется: секрет для верификации вебхука (задать в @BotFather → Webhook Secret)
WEBHOOK_SECRET=

# ── База данных ────────────────────────────────────────────────────────────────
# Обязательно для production: строка подключения PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/maminhleb

# SSL-режим: no-verify (Railway, self-signed) | verify (собственный CA)
DATABASE_SSL=no-verify

# ── Сервер ────────────────────────────────────────────────────────────────────
PORT=3000

# CORS: разрешённые origins через запятую (по умолчанию * — только для dev)
ALLOWED_ORIGINS=https://yourdomain.com

# ── Вебхук ────────────────────────────────────────────────────────────────────
# Railway подставляет RAILWAY_PUBLIC_DOMAIN автоматически.
# Для локальной разработки укажи ngrok-URL:
# WEBHOOK_BASE_URL=https://abc123.ngrok.io
